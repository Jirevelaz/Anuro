---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { sanityClient } from "sanity:client"
import { urlFor } from "../../lib/sanity"

// ── GROQ: traer todos los posts con sus referencias resueltas ──
const posts = await sanityClient.fetch(
  `*[_type == "post"] | order(publishedAt desc) {
    _id,
    title,
    "slug": slug.current,
    mainImage,
    publishedAt,
    isFeatured,
    category->{ _id, title },
    tags[]->{ _id, title },
    "excerpt": pt::text(body)
  }`
)

// ── Hero: el post destacado más reciente ──
const heroPost = posts.find((p: any) => p.isFeatured === true) || posts[0]

// ── Grid: el resto de posts (sin el hero) ──
const gridPosts = posts.filter((p: any) => p._id !== heroPost?._id)

// ── Categorías únicas para los filtros ──
const allCategories = [
  ...new Set(
    posts
      .map((p: any) => p.category?.title)
      .filter(Boolean)
  ),
] as string[]

// ── Helpers ──
function formatDate(dateStr: string) {
  if (!dateStr) return ""
  return new Date(dateStr).toLocaleDateString("es-MX", {
    day: "numeric",
    month: "short",
    year: "numeric",
  })
}

function truncate(text: string, max = 160) {
  if (!text) return ""
  return text.length > max ? text.slice(0, max).trimEnd() + "…" : text
}
---

<BaseLayout
  title="Bitácora · ANURO"
  description="Notas, ensayos y curaduría desde el club de vinilos ANURO."
>
  <!-- HERO EDITORIAL -->
  <section class="relative border-b border-foreground/10">
    <div class="paper-grain absolute inset-0 opacity-50 pointer-events-none"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-primary">
            Bitácora
          </p>
          <h1 class="mt-4 font-display text-5xl leading-[0.95] tracking-tight md:text-7xl lg:text-8xl">
            Notas desde<br />
            <span class="text-primary">el club</span>.
          </h1>
        </div>
        <p class="max-w-sm text-muted-foreground md:text-right md:text-lg">
          Curaduría, ensayos, entrevistas, y todo lo que pasa entre bambalinas
          cuando armamos un Disco del Mes.
        </p>
      </div>
    </div>
  </section>

  <!-- FEATURED POST (HERO POST) -->
  {heroPost && (
    <section class="mx-auto max-w-7xl px-4 py-12 md:px-8 md:py-16">
      <a
        href={`/bitacora/${heroPost.slug}`}
        class="group relative grid gap-0 overflow-hidden rounded-2xl border border-foreground/10 bg-card md:grid-cols-2"
      >
        <!-- Image -->
        <div class="relative aspect-[4/3] overflow-hidden md:aspect-auto md:min-h-[480px]">
          {heroPost.mainImage ? (
            <img
              src={urlFor(heroPost.mainImage).width(960).height(720).format("webp").url()}
              alt={heroPost.title}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="eager"
              width="960"
              height="720"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center bg-muted">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-muted-foreground/40">
                <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
                <circle cx="9" cy="9" r="2"></circle>
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
              </svg>
            </div>
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-foreground/20 to-transparent md:bg-gradient-to-r md:from-transparent md:to-foreground/10"></div>

          <!-- Badge -->
          <span class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-accent-foreground">
            Destacado
          </span>
        </div>

        <!-- Content -->
        <div class="flex flex-col justify-center gap-6 p-8 md:p-12 lg:p-16">
          <div class="flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
            {heroPost.category?.title && (
              <>
                <span>{heroPost.category.title}</span>
                <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
              </>
            )}
            {heroPost.publishedAt && (
              <time datetime={heroPost.publishedAt}>{formatDate(heroPost.publishedAt)}</time>
            )}
          </div>

          <h2 class="font-display text-3xl leading-tight tracking-tight md:text-4xl lg:text-5xl">
            {heroPost.title}
          </h2>

          {heroPost.excerpt && (
            <p class="text-muted-foreground leading-relaxed md:text-lg">
              {truncate(heroPost.excerpt, 220)}
            </p>
          )}

          <span class="inline-flex w-fit items-center gap-3 rounded-full border border-foreground/20 px-5 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors group-hover:border-primary group-hover:bg-primary group-hover:text-primary-foreground">
            Leer artículo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </span>
        </div>
      </a>
    </section>
  )}

  <!-- CATEGORY FILTER CHIPS -->
  {allCategories.length > 0 && (
    <section class="sticky top-[57px] z-30 border-b border-foreground/10 bg-background/95 backdrop-blur-sm">
      <div class="mx-auto max-w-7xl px-4 md:px-8">
        <nav id="category-filters" class="flex items-center gap-2 overflow-x-auto py-4 scrollbar-hide" aria-label="Filtrar por categoría">
          <button
            type="button"
            data-filter="all"
            class="filter-chip active shrink-0 rounded-full px-4 py-2 font-mono text-xs uppercase tracking-wider transition-colors bg-foreground text-background"
          >
            Todo
          </button>
          {allCategories.map((cat) => (
            <button
              type="button"
              data-filter={cat}
              class="filter-chip shrink-0 rounded-full px-4 py-2 font-mono text-xs uppercase tracking-wider transition-colors text-muted-foreground hover:bg-foreground/5 hover:text-foreground"
            >
              {cat}
            </button>
          ))}
        </nav>
      </div>
    </section>
  )}

  <!-- ARTICLES GRID -->
  <section class="mx-auto max-w-7xl px-4 py-12 pb-20 md:px-8 md:py-16 md:pb-24">
    {gridPosts.length > 0 && (
      <div class="mb-8 flex items-center justify-between border-b border-foreground/10 pb-4">
        <h3 class="font-display text-2xl">Últimos artículos</h3>
        <span id="post-count" class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
          {gridPosts.length} artículo{gridPosts.length !== 1 ? "s" : ""}
        </span>
      </div>
    )}

    <div id="posts-grid" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {gridPosts.map((post: any) => (
        <a
          href={`/bitacora/${post.slug}`}
          class="post-card group flex flex-col"
          data-category={post.category?.title || ""}
        >
          <!-- Image Container -->
          <div class="relative aspect-[4/3] overflow-hidden rounded-xl bg-muted">
            {post.mainImage ? (
              <img
                src={urlFor(post.mainImage).width(640).height(480).format("webp").url()}
                alt={post.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="640"
                height="480"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center bg-muted">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-muted-foreground/40">
                  <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
                  <circle cx="9" cy="9" r="2"></circle>
                  <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
                </svg>
              </div>
            )}
            <!-- Category Pill -->
            {post.category?.title && (
              <span class="absolute left-3 top-3 rounded-full bg-background/90 px-2.5 py-1 font-mono text-[9px] uppercase tracking-widest backdrop-blur-sm">
                {post.category.title}
              </span>
            )}
          </div>

          <!-- Content -->
          <div class="flex flex-1 flex-col gap-3 pt-5">
            <!-- Meta -->
            <div class="flex flex-wrap items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
              {post.publishedAt && (
                <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
              )}
              {post.tags && post.tags.length > 0 && (
                <>
                  <span class="h-0.5 w-0.5 rounded-full bg-foreground/30"></span>
                  {post.tags.slice(0, 2).map((tag: any, i: number) => (
                    <>
                      {i > 0 && <span class="text-foreground/20">·</span>}
                      <span class="text-primary/80">{tag.title}</span>
                    </>
                  ))}
                </>
              )}
            </div>

            <!-- Title -->
            <h4 class="font-display text-xl leading-tight transition-colors group-hover:text-primary md:text-2xl">
              {post.title}
            </h4>

            <!-- Excerpt -->
            {post.excerpt && (
              <p class="line-clamp-2 text-sm leading-relaxed text-muted-foreground">
                {truncate(post.excerpt)}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden py-20 text-center">
      <p class="font-display text-2xl text-muted-foreground">No hay artículos en esta categoría.</p>
      <button
        type="button"
        id="reset-filter"
        class="mt-4 rounded-full border border-foreground/20 px-6 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors hover:bg-foreground/5"
      >
        Ver todos
      </button>
    </div>
  </section>
</BaseLayout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .post-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .post-card.is-hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter-chip")
    const cards = document.querySelectorAll<HTMLElement>(".post-card")
    const postCount = document.getElementById("post-count")
    const emptyState = document.getElementById("empty-state")
    const resetButton = document.getElementById("reset-filter")

    if (!filterButtons.length || !cards.length) return

    function setActiveFilter(selectedCategory: string) {
      // Actualizar estado visual de las píldoras
      filterButtons.forEach((btn) => {
        const isActive =
          btn.dataset.filter === selectedCategory ||
          (selectedCategory === "all" && btn.dataset.filter === "all")

        if (isActive) {
          btn.classList.add("bg-foreground", "text-background")
          btn.classList.remove(
            "text-muted-foreground",
            "hover:bg-foreground/5",
            "hover:text-foreground"
          )
          btn.classList.add("active")
        } else {
          btn.classList.remove("bg-foreground", "text-background", "active")
          btn.classList.add(
            "text-muted-foreground",
            "hover:bg-foreground/5",
            "hover:text-foreground"
          )
        }
      })

      // Filtrar tarjetas
      let visibleCount = 0
      cards.forEach((card) => {
        const cardCategory = card.dataset.category || ""
        const shouldShow =
          selectedCategory === "all" || cardCategory === selectedCategory

        if (shouldShow) {
          card.classList.remove("is-hidden")
          visibleCount++
        } else {
          card.classList.add("is-hidden")
        }
      })

      // Actualizar contador
      if (postCount) {
        postCount.textContent = `${visibleCount} artículo${visibleCount !== 1 ? "s" : ""}`
      }

      // Mostrar/ocultar estado vacío
      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0)
      }
    }

    // Event listeners para los botones de filtro
    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter || "all"
        setActiveFilter(filter)
      })
    })

    // Botón de reset en el estado vacío
    if (resetButton) {
      resetButton.addEventListener("click", () => {
        setActiveFilter("all")
      })
    }
  })
</script>
