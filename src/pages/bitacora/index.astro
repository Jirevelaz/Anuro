---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { sanityClient } from "sanity:client"
import { urlFor } from "../../lib/sanity"

// ── GROQ: traer todos los posts con sus referencias resueltas ──
const posts = await sanityClient.fetch(
  `*[_type == "post"] | order(publishedAt desc) {
    _id,
    title,
    subtitle,
    "slug": slug.current,
    mainImage,
    publishedAt,
    isFeatured,
    author,
    estimatedReadingTime,
    category->{ _id, title },
    tags[]->{ _id, title },
    "excerpt": pt::text(body)
  }`
)

// ── Hero: el post destacado más reciente ──
const heroPost = posts.find((p: any) => p.isFeatured === true) || posts[0]

// ── Feed: el resto de posts (sin el hero) ──
const feedPosts = posts.filter((p: any) => p._id !== heroPost?._id)

// ── Categorías únicas para los filtros ──
const allCategories = [
  ...new Set(
    posts
      .map((p: any) => p.category?.title)
      .filter(Boolean)
  ),
] as string[]

// ── Helpers ──
function formatDate(dateStr: string) {
  if (!dateStr) return ""
  return new Date(dateStr).toLocaleDateString("es-MX", {
    day: "numeric",
    month: "long",
    year: "numeric",
  })
}

function truncate(text: string, max = 200) {
  if (!text) return ""
  return text.length > max ? text.slice(0, max).trimEnd() + "…" : text
}
---

<BaseLayout
  title="Bitácora · ANURO"
  description="Ensayos, reseñas y curaduría musical desde el sello discográfico ANURO."
>
  <!-- HEADER EDITORIAL -->
  <section class="relative border-b border-foreground/10">
    <div class="paper-grain absolute inset-0 opacity-50 pointer-events-none"></div>
    <div class="relative mx-auto max-w-3xl px-4 py-16 text-center md:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-primary">
        La Bitácora
      </p>
      <h1 class="mt-5 font-display text-5xl leading-[0.95] tracking-tight md:text-7xl">
        Curaduría &<br />Cultura Musical
      </h1>
      <p class="mx-auto mt-6 max-w-lg text-muted-foreground md:text-lg">
        Ensayos, reseñas, entrevistas y selecciones curadas desde ANURO.
        Historias que suenan tan bien como los discos que vendemos.
      </p>

      <!-- Newsletter CTA -->
      <form class="mx-auto mt-8 flex max-w-md overflow-hidden rounded-full border border-foreground/15 bg-card">
        <input
          type="email"
          required
          placeholder="tu@correo.com"
          class="flex-1 bg-transparent px-5 py-3.5 text-sm outline-none placeholder:text-muted-foreground"
        />
        <button
          type="submit"
          class="shrink-0 bg-foreground px-6 font-display text-sm uppercase tracking-wide text-background transition-colors hover:bg-foreground/90"
        >
          Suscribirse
        </button>
      </form>
      <p class="mt-3 font-mono text-[10px] uppercase tracking-widest text-muted-foreground/60">
        Sin spam · Cancelar cuando quieras
      </p>
    </div>
  </section>

  <!-- FEATURED POST -->
  {heroPost && (
    <section class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
      <a
        href={`/bitacora/${heroPost.slug}`}
        class="group block"
      >
        <!-- Image -->
        {heroPost.mainImage && (
          <div class="relative aspect-[16/9] overflow-hidden rounded-2xl">
            <img
              src={urlFor(heroPost.mainImage).width(1200).height(675).format("webp").url()}
              alt={heroPost.title}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              loading="eager"
              width="1200"
              height="675"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-foreground/30 via-transparent to-transparent"></div>

            <!-- Badge -->
            <span class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-accent-foreground">
              Destacado
            </span>
          </div>
        )}

        <!-- Content -->
        <div class="mt-6 max-w-3xl">
          <div class="flex flex-wrap items-center gap-2 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
            {heroPost.category?.title && (
              <>
                <span class="text-primary">{heroPost.category.title}</span>
                <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
              </>
            )}
            {heroPost.publishedAt && (
              <time datetime={heroPost.publishedAt}>{formatDate(heroPost.publishedAt)}</time>
            )}
            {heroPost.estimatedReadingTime && (
              <>
                <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
                <span>{heroPost.estimatedReadingTime} min de lectura</span>
              </>
            )}
          </div>

          <h2 class="mt-3 font-display text-3xl leading-tight tracking-tight transition-colors group-hover:text-primary md:text-4xl lg:text-5xl">
            {heroPost.title}
          </h2>

          {heroPost.subtitle && (
            <p class="mt-3 text-lg text-muted-foreground">
              {heroPost.subtitle}
            </p>
          )}

          {heroPost.excerpt && !heroPost.subtitle && (
            <p class="mt-3 text-muted-foreground md:text-lg">
              {truncate(heroPost.excerpt, 260)}
            </p>
          )}

          <!-- Author -->
          {heroPost.author?.name && (
            <div class="mt-5 flex items-center gap-3">
              {heroPost.author.image ? (
                <img
                  src={urlFor(heroPost.author.image).width(80).height(80).format("webp").url()}
                  alt={heroPost.author.name}
                  class="h-8 w-8 rounded-full object-cover"
                  width="40"
                  height="40"
                />
              ) : (
                <div class="grid h-8 w-8 place-items-center rounded-full bg-primary/10 text-primary">
                  <span class="font-display text-sm">{heroPost.author.name[0]}</span>
                </div>
              )}
              <span class="text-sm text-muted-foreground">
                Por <span class="font-medium text-foreground">{heroPost.author.name}</span>
              </span>
            </div>
          )}
        </div>
      </a>
    </section>
  )}

  <!-- CATEGORY FILTER PILLS -->
  {allCategories.length > 0 && (
    <section class="sticky top-[57px] z-30 border-y border-foreground/10 bg-background/95 backdrop-blur-sm">
      <div class="mx-auto max-w-5xl px-4 md:px-8">
        <nav id="category-filters" class="flex items-center gap-2 overflow-x-auto py-4 scrollbar-hide" aria-label="Filtrar por categoría">
          <button
            type="button"
            data-filter="all"
            class="filter-chip active shrink-0 rounded-full px-4 py-2 font-mono text-xs uppercase tracking-wider transition-colors bg-foreground text-background"
          >
            Todo
          </button>
          {allCategories.map((cat) => (
            <button
              type="button"
              data-filter={cat}
              class="filter-chip shrink-0 rounded-full px-4 py-2 font-mono text-xs uppercase tracking-wider transition-colors text-muted-foreground hover:bg-foreground/5 hover:text-foreground"
            >
              {cat}
            </button>
          ))}
        </nav>
      </div>
    </section>
  )}

  <!-- EDITORIAL FEED -->
  <section class="mx-auto max-w-5xl px-4 py-12 pb-20 md:px-8 md:py-16 md:pb-24">
    {feedPosts.length > 0 && (
      <div class="mb-8 flex items-center justify-between border-b border-foreground/10 pb-4">
        <h3 class="font-display text-2xl">Artículos</h3>
        <span id="post-count" class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
          {feedPosts.length} artículo{feedPosts.length !== 1 ? "s" : ""}
        </span>
      </div>
    )}

    <div id="posts-feed" class="flex flex-col divide-y divide-foreground/8">
      {feedPosts.map((post: any) => (
        <a
          href={`/bitacora/${post.slug}`}
          class="post-card group flex gap-6 py-8 first:pt-0 md:gap-10"
          data-category={post.category?.title || ""}
        >
          <!-- Text content -->
          <div class="flex flex-1 flex-col justify-center gap-3">
            <!-- Meta -->
            <div class="flex flex-wrap items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
              {post.category?.title && (
                <>
                  <span class="text-primary">{post.category.title}</span>
                  <span class="h-0.5 w-0.5 rounded-full bg-foreground/30"></span>
                </>
              )}
              {post.publishedAt && (
                <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
              )}
              {post.estimatedReadingTime && (
                <>
                  <span class="h-0.5 w-0.5 rounded-full bg-foreground/30"></span>
                  <span>{post.estimatedReadingTime} min</span>
                </>
              )}
            </div>

            <!-- Title -->
            <h4 class="font-display text-xl leading-tight transition-colors group-hover:text-primary md:text-2xl">
              {post.title}
            </h4>

            <!-- Subtitle or excerpt -->
            {post.subtitle ? (
              <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
                {post.subtitle}
              </p>
            ) : post.excerpt ? (
              <p class="line-clamp-2 text-sm leading-relaxed text-muted-foreground">
                {truncate(post.excerpt, 180)}
              </p>
            ) : null}

            <!-- Author -->
            {post.author?.name && (
              <div class="mt-1 flex items-center gap-2">
                {post.author.image ? (
                  <img
                    src={urlFor(post.author.image).width(48).height(48).format("webp").url()}
                    alt={post.author.name}
                    class="h-5 w-5 rounded-full object-cover"
                    width="24"
                    height="24"
                  />
                ) : (
                  <div class="grid h-5 w-5 place-items-center rounded-full bg-primary/10 text-primary">
                    <span class="font-display text-[9px]">{post.author.name[0]}</span>
                  </div>
                )}
                <span class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground">
                  {post.author.name}
                </span>
              </div>
            )}
          </div>

          <!-- Thumbnail -->
          <div class="relative aspect-square w-28 shrink-0 overflow-hidden rounded-xl bg-muted md:w-44 md:aspect-[4/3]">
            {post.mainImage ? (
              <img
                src={urlFor(post.mainImage).width(352).height(264).format("webp").url()}
                alt={post.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="352"
                height="264"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center bg-muted">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-muted-foreground/40">
                  <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
                  <circle cx="9" cy="9" r="2"></circle>
                  <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
                </svg>
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden py-20 text-center">
      <p class="font-display text-2xl text-muted-foreground">No hay artículos en esta categoría.</p>
      <button
        type="button"
        id="reset-filter"
        class="mt-4 rounded-full border border-foreground/20 px-6 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors hover:bg-foreground/5"
      >
        Ver todos
      </button>
    </div>
  </section>
</BaseLayout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .post-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .post-card.is-hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter-chip")
    const cards = document.querySelectorAll<HTMLElement>(".post-card")
    const postCount = document.getElementById("post-count")
    const emptyState = document.getElementById("empty-state")
    const resetButton = document.getElementById("reset-filter")

    if (!filterButtons.length || !cards.length) return

    function setActiveFilter(selectedCategory: string) {
      filterButtons.forEach((btn) => {
        const isActive =
          btn.dataset.filter === selectedCategory ||
          (selectedCategory === "all" && btn.dataset.filter === "all")

        if (isActive) {
          btn.classList.add("bg-foreground", "text-background")
          btn.classList.remove(
            "text-muted-foreground",
            "hover:bg-foreground/5",
            "hover:text-foreground"
          )
          btn.classList.add("active")
        } else {
          btn.classList.remove("bg-foreground", "text-background", "active")
          btn.classList.add(
            "text-muted-foreground",
            "hover:bg-foreground/5",
            "hover:text-foreground"
          )
        }
      })

      let visibleCount = 0
      cards.forEach((card) => {
        const cardCategory = card.dataset.category || ""
        const shouldShow =
          selectedCategory === "all" || cardCategory === selectedCategory

        if (shouldShow) {
          card.classList.remove("is-hidden")
          visibleCount++
        } else {
          card.classList.add("is-hidden")
        }
      })

      if (postCount) {
        postCount.textContent = `${visibleCount} artículo${visibleCount !== 1 ? "s" : ""}`
      }

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0)
      }
    }

    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter || "all"
        setActiveFilter(filter)
      })
    })

    if (resetButton) {
      resetButton.addEventListener("click", () => {
        setActiveFilter("all")
      })
    }
  })
</script>
