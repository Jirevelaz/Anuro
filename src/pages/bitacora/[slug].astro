---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { PortableText } from "astro-portabletext"
import { sanityClient } from "sanity:client"
import { urlFor } from "../../lib/sanity"

// ── Rutas estáticas: Astro necesita saber todos los slugs al build ──
export async function getStaticPaths() {
  const posts = await sanityClient.fetch(
    `*[_type == "post" && defined(slug.current)]{
      "slug": slug.current
    }`
  )

  return posts.map((post: any) => ({
    params: { slug: post.slug },
  }))
}

// ── Obtener el post completo por slug ──
const { slug } = Astro.params

const post = await sanityClient.fetch(
  `*[_type == "post" && slug.current == $slug][0]{
    _id,
    title,
    "slug": slug.current,
    mainImage,
    publishedAt,
    isFeatured,
    category->{ _id, title },
    tags[]->{ _id, title },
    body
  }`,
  { slug }
)

if (!post) {
  return Astro.redirect("/bitacora")
}

// ── Helpers ──
function formatDate(dateStr: string) {
  if (!dateStr) return ""
  return new Date(dateStr).toLocaleDateString("es-MX", {
    day: "numeric",
    month: "long",
    year: "numeric",
  })
}

// ── Posts relacionados (misma categoría, excluyendo el actual) ──
const relatedPosts = post.category
  ? await sanityClient.fetch(
      `*[_type == "post" && category._ref == $catRef && _id != $id] | order(publishedAt desc)[0...3]{
        _id,
        title,
        "slug": slug.current,
        mainImage,
        publishedAt,
        category->{ title }
      }`,
      { catRef: post.category._id, id: post._id }
    )
  : []
---

<BaseLayout
  title={`${post.title} · Bitácora ANURO`}
  description={post.title}
>
  <!-- ARTICLE -->
  <article>
    <!-- HERO IMAGE -->
    {post.mainImage && (
      <section class="relative overflow-hidden border-b border-foreground/10">
        <div class="mx-auto max-w-7xl px-4 pt-8 md:px-8 md:pt-12">
          <div class="relative aspect-[21/9] overflow-hidden rounded-2xl md:rounded-3xl">
            <img
              src={urlFor(post.mainImage).width(1400).height(600).format("webp").url()}
              alt={post.title}
              class="h-full w-full object-cover"
              loading="eager"
              width="1400"
              height="600"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-foreground/30 via-transparent to-transparent"></div>
          </div>
        </div>
      </section>
    )}

    <!-- ARTICLE HEADER -->
    <section class="mx-auto max-w-3xl px-4 pt-10 md:px-8 md:pt-16">
      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
        <a href="/bitacora" class="transition-colors hover:text-primary">Bitácora</a>
        {post.category?.title && (
          <>
            <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
            <span class="text-primary">{post.category.title}</span>
          </>
        )}
        {post.publishedAt && (
          <>
            <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
            <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
          </>
        )}
      </div>

      <!-- Title -->
      <h1 class="mt-6 font-display text-4xl leading-[1.05] tracking-tight md:text-5xl lg:text-6xl">
        {post.title}
      </h1>

      <!-- Tags -->
      {post.tags && post.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {post.tags.map((tag: any) => (
            <span class="rounded-full border border-foreground/15 px-3 py-1 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
              {tag.title}
            </span>
          ))}
        </div>
      )}
    </section>

    <!-- ARTICLE BODY -->
    <section class="mx-auto max-w-3xl px-4 py-12 md:px-8 md:py-16">
      <div class="portable-text">
        <PortableText value={post.body} />
      </div>
    </section>

    <!-- BACK LINK -->
    <section class="mx-auto max-w-3xl px-4 pb-12 md:px-8">
      <div class="border-t border-foreground/10 pt-8">
        <a
          href="/bitacora"
          class="group inline-flex items-center gap-3 rounded-full border border-foreground/20 px-5 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors hover:border-primary hover:bg-primary hover:text-primary-foreground"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1">
            <path d="M19 12H5"></path>
            <path d="m12 19-7-7 7-7"></path>
          </svg>
          Volver a la Bitácora
        </a>
      </div>
    </section>
  </article>

  <!-- RELATED POSTS -->
  {relatedPosts.length > 0 && (
    <section class="border-t border-foreground/10">
      <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
        <div class="mb-10 flex items-center justify-between">
          <h2 class="font-display text-2xl md:text-3xl">Más en {post.category?.title}</h2>
        </div>

        <div class="grid gap-8 md:grid-cols-3">
          {relatedPosts.map((related: any) => (
            <a
              href={`/bitacora/${related.slug}`}
              class="group flex flex-col"
            >
              <div class="relative aspect-[4/3] overflow-hidden rounded-xl bg-muted">
                {related.mainImage ? (
                  <img
                    src={urlFor(related.mainImage).width(480).height(360).format("webp").url()}
                    alt={related.title}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    width="480"
                    height="360"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-muted">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-muted-foreground/40">
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
                      <circle cx="9" cy="9" r="2"></circle>
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
                    </svg>
                  </div>
                )}
              </div>
              <div class="flex flex-col gap-2 pt-5">
                {related.publishedAt && (
                  <time class="font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                    {formatDate(related.publishedAt)}
                  </time>
                )}
                <h3 class="font-display text-xl leading-tight transition-colors group-hover:text-primary md:text-2xl">
                  {related.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Tipografía para el cuerpo del artículo (Portable Text) */
  .portable-text {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--foreground);
  }

  .portable-text :global(h2) {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .portable-text :global(h3) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .portable-text :global(h4) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    line-height: 1.4;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .portable-text :global(p) {
    margin-bottom: 1.5rem;
    color: var(--foreground);
  }

  .portable-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .portable-text :global(strong) {
    font-weight: 600;
    color: var(--foreground);
  }

  .portable-text :global(em) {
    font-style: italic;
  }

  .portable-text :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s, text-decoration-color 0.2s;
  }

  .portable-text :global(a:hover) {
    color: var(--accent);
  }

  .portable-text :global(blockquote) {
    border-left: 3px solid var(--primary);
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--muted-foreground);
  }

  .portable-text :global(ul),
  .portable-text :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .portable-text :global(ul) {
    list-style-type: disc;
  }

  .portable-text :global(ol) {
    list-style-type: decimal;
  }

  .portable-text :global(li) {
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
  }

  .portable-text :global(li::marker) {
    color: var(--primary);
  }

  .portable-text :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .portable-text :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--muted);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .portable-text :global(pre) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--foreground);
    color: var(--background);
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin: 2rem 0;
  }

  .portable-text :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    color: inherit;
  }
</style>
