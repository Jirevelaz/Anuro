---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { PortableText } from "astro-portabletext"
import { sanityClient } from "sanity:client"
import { urlFor } from "../../lib/sanity"
import YoutubeBlock from "../../components/portabletext/YoutubeBlock.astro"
import ReleaseBlock from "../../components/portabletext/ReleaseBlock.astro"
import GalleryBlock from "../../components/portabletext/GalleryBlock.astro"
import ImageBlock from "../../components/portabletext/ImageBlock.astro"

// ── Rutas estáticas: Astro necesita saber todos los slugs al build ──
export async function getStaticPaths() {
  const posts = await sanityClient.fetch(
    `*[_type == "post" && defined(slug.current)]{
      "slug": slug.current
    }`
  )

  return posts.map((post: any) => ({
    params: { slug: post.slug },
  }))
}

// ── Obtener el post completo por slug ──
const { slug } = Astro.params

const post = await sanityClient.fetch(
  `*[_type == "post" && slug.current == $slug][0]{
    _id,
    title,
    subtitle,
    "slug": slug.current,
    mainImage,
    publishedAt,
    isFeatured,
    author,
    estimatedReadingTime,
    category->{ _id, title },
    tags[]->{ _id, title },
    body[]{
      ...,
      _type == "releaseReference" => {
        ...,
        release->{
          title,
          artist,
          coverImage,
          slug,
          price
        }
      }
    }
  }`,
  { slug }
)

if (!post) {
  return Astro.redirect("/bitacora")
}

// ── Helpers ──
function formatDate(dateStr: string) {
  if (!dateStr) return ""
  return new Date(dateStr).toLocaleDateString("es-MX", {
    day: "numeric",
    month: "long",
    year: "numeric",
  })
}

// ── Posts relacionados (misma categoría, excluyendo el actual) ──
const relatedPosts = post.category
  ? await sanityClient.fetch(
      `*[_type == "post" && category._ref == $catRef && _id != $id] | order(publishedAt desc)[0...3]{
        _id,
        title,
        subtitle,
        "slug": slug.current,
        mainImage,
        publishedAt,
        author,
        category->{ title }
      }`,
      { catRef: post.category._id, id: post._id }
    )
  : []

const currentUrl = Astro.url.href
---

<BaseLayout
  title={`${post.title} · Bitácora ANURO`}
  description={post.subtitle || post.title}
>
  <article class="bg-background pb-20 pt-10 md:pt-16">
    <!-- HEADER ARTICLE -->
    <header class="mx-auto max-w-3xl px-4 text-center md:px-8">
      <!-- Title & Subtitle -->
      <h1 class="font-display text-4xl leading-[1.05] tracking-tight md:text-5xl lg:text-6xl">
        {post.title}
      </h1>
      
      {post.subtitle && (
        <p class="mt-4 font-sans text-xl leading-relaxed text-muted-foreground md:text-2xl">
          {post.subtitle}
        </p>
      )}

      <!-- Author Byline & Meta -->
      <div class="mt-8 flex flex-col items-center justify-center gap-4 border-y border-foreground/10 py-5 sm:flex-row">
        {post.author?.name && (
          <div class="flex items-center gap-3">
            {post.author.image ? (
              <img
                src={urlFor(post.author.image).width(80).height(80).format("webp").url()}
                alt={post.author.name}
                class="h-10 w-10 rounded-full object-cover"
                width="40"
                height="40"
              />
            ) : (
              <div class="grid h-10 w-10 place-items-center rounded-full bg-primary/10 text-primary">
                <span class="font-display text-lg">{post.author.name[0]}</span>
              </div>
            )}
            <div class="flex flex-col items-start text-sm">
              <span class="font-medium text-foreground">{post.author.name}</span>
              <div class="flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                {post.publishedAt && <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>}
                {post.estimatedReadingTime && (
                  <>
                    <span class="h-0.5 w-0.5 rounded-full bg-foreground/30"></span>
                    <span>{post.estimatedReadingTime} min</span>
                  </>
                )}
              </div>
            </div>
          </div>
        )}
        
        {/* Extra meta if no author */}
        {!post.author?.name && (
           <div class="flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
              {post.publishedAt && <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>}
              {post.estimatedReadingTime && (
                <>
                  <span class="h-0.5 w-0.5 rounded-full bg-foreground/30"></span>
                  <span>{post.estimatedReadingTime} min</span>
                </>
              )}
            </div>
        )}
      </div>
    </header>

    <!-- HERO IMAGE (INLINE) -->
    {post.mainImage && (
      <figure class="mx-auto mt-10 max-w-4xl px-4 md:px-8">
        <div class="overflow-hidden rounded-2xl bg-muted">
          <img
            src={urlFor(post.mainImage).width(1200).height(800).format("webp").url()}
            alt={post.title}
            class="h-auto w-full object-cover"
            loading="eager"
            width="1200"
            height="800"
          />
        </div>
      </figure>
    )}

    <!-- ARTICLE BODY -->
    <div class="mx-auto mt-12 max-w-3xl px-4 md:mt-16 md:px-8">
      <div class="portable-text">
        <PortableText 
          value={post.body} 
          components={{
            type: {
              youtube: YoutubeBlock,
              releaseReference: ReleaseBlock,
              gallery: GalleryBlock,
              image: ImageBlock
            }
          }}
        />
      </div>
      
      <!-- Tags -->
      {post.tags && post.tags.length > 0 && (
        <div class="mt-12 flex flex-wrap gap-2 border-t border-foreground/10 pt-8">
          {post.tags.map((tag: any) => (
            <span class="cursor-pointer rounded-full bg-foreground/5 px-3 py-1 font-mono text-[10px] uppercase tracking-widest text-muted-foreground transition-colors hover:bg-foreground/10 hover:text-foreground">
              {tag.title}
            </span>
          ))}
        </div>
      )}
      
      <!-- Interaction / Share strip -->
      <div class="mt-8 flex flex-col justify-between gap-4 border-y border-foreground/10 py-4 sm:flex-row sm:items-center">
        <div class="flex items-center gap-4 text-muted-foreground">
          <button class="group flex items-center gap-2 transition-colors hover:text-foreground">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-all group-hover:fill-current group-hover:text-red-500"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            <span class="font-mono text-xs uppercase tracking-wider">Me gusta</span>
          </button>
          <a href="#comments" class="flex items-center gap-2 transition-colors hover:text-foreground">
             <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
             <span class="font-mono text-xs uppercase tracking-wider">Comentar</span>
          </a>
        </div>
        <div class="flex items-center gap-3 text-muted-foreground">
          <button onclick={`navigator.clipboard.writeText('${currentUrl}')`} class="flex items-center gap-2 transition-colors hover:text-foreground" title="Copiar enlace">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          </button>
        </div>
      </div>

      <!-- Author Bio Box -->
      {post.author?.name && (
        <div class="mt-12 flex flex-col gap-6 rounded-2xl border border-foreground/10 bg-card p-6 sm:flex-row md:p-8">
          {post.author.image ? (
            <img
              src={urlFor(post.author.image).width(160).height(160).format("webp").url()}
              alt={post.author.name}
              class="h-20 w-20 shrink-0 rounded-full object-cover"
              width="80"
              height="80"
            />
          ) : (
            <div class="grid h-20 w-20 shrink-0 place-items-center rounded-full bg-primary/10 text-primary">
              <span class="font-display text-3xl">{post.author.name[0]}</span>
            </div>
          )}
          <div class="flex flex-col justify-center">
            <span class="mb-1 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">Escrito por</span>
            <h3 class="font-display text-2xl">{post.author.name}</h3>
            {post.author.bio && (
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                {post.author.bio}
              </p>
            )}
          </div>
        </div>
      )}

      <!-- Inline Newsletter CTA -->
      <div class="mt-12 rounded-2xl border border-foreground/15 bg-foreground p-8 text-center text-background">
        <h3 class="font-display text-2xl">Recibe nuevas notas en tu correo</h3>
        <p class="mt-2 text-sm text-background/70">Únete a nuestra lista para recibir curaduría musical directamente en tu bandeja de entrada.</p>
        <form class="mx-auto mt-6 flex max-w-sm flex-col gap-3 sm:flex-row sm:rounded-full sm:bg-background/10 sm:p-1">
          <input
            type="email"
            required
            placeholder="tu@correo.com"
            class="flex-1 rounded-full bg-background/10 px-5 py-3 text-sm text-background outline-none placeholder:text-background/50 sm:bg-transparent"
          />
          <button
            type="submit"
            class="rounded-full bg-background px-6 py-3 font-display text-sm uppercase tracking-wide text-foreground transition-colors hover:bg-background/90"
          >
            Suscribirse
          </button>
        </form>
      </div>

    </div>
  </article>

  <!-- RELATED POSTS -->
  {relatedPosts.length > 0 && (
    <section class="border-t border-foreground/10 bg-card">
      <div class="mx-auto max-w-5xl px-4 py-16 md:px-8 md:py-20">
        <div class="mb-10 text-center">
          <h2 class="font-display text-3xl md:text-4xl">Sigue leyendo</h2>
          <div class="mt-4 flex justify-center">
             <div class="h-1 w-12 rounded-full bg-foreground/20"></div>
          </div>
        </div>

        <div class="grid gap-8 md:grid-cols-2">
          {relatedPosts.slice(0, 2).map((related: any) => (
            <a
              href={`/bitacora/${related.slug}`}
              class="group flex flex-col gap-4"
            >
              <div class="relative aspect-[16/9] overflow-hidden rounded-xl bg-muted">
                {related.mainImage ? (
                  <img
                    src={urlFor(related.mainImage).width(800).height(450).format("webp").url()}
                    alt={related.title}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    width="800"
                    height="450"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-muted">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-muted-foreground/40">
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
                      <circle cx="9" cy="9" r="2"></circle>
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
                    </svg>
                  </div>
                )}
              </div>
              <div class="flex flex-col gap-2">
                <div class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                   {related.author?.name && <span>{related.author.name}</span>}
                   {related.author?.name && related.publishedAt && <span class="h-0.5 w-0.5 rounded-full bg-foreground/30"></span>}
                   {related.publishedAt && <time>{formatDate(related.publishedAt)}</time>}
                </div>
                <h3 class="font-display text-2xl leading-tight transition-colors group-hover:text-primary">
                  {related.title}
                </h3>
                {related.subtitle && (
                   <p class="line-clamp-2 text-sm text-muted-foreground">{related.subtitle}</p>
                )}
              </div>
            </a>
          ))}
        </div>
        
        <div class="mt-12 text-center">
           <a href="/bitacora" class="inline-flex items-center gap-2 rounded-full border border-foreground/20 px-6 py-3 font-mono text-xs uppercase tracking-wider transition-colors hover:bg-foreground/5">
             Ver todas las notas
           </a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Tipografía Editorial (Portable Text) - Substack Style */
  .portable-text {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--foreground);
    letter-spacing: -0.01em;
    overflow: visible;
  }

  /* Make paragraphs look more like Substack (a bit more spaced, nice readability) */
  .portable-text :global(p) {
    margin-bottom: 1.75rem;
    color: var(--foreground);
    opacity: 0.9;
    text-align: justify;
    text-justify: inter-word;
    hyphens: auto;
  }

  .portable-text :global(h2) {
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
  }

  .portable-text :global(h3) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .portable-text :global(strong) {
    font-weight: 600;
    color: var(--foreground);
  }

  .portable-text :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    transition: color 0.2s, text-decoration-color 0.2s;
  }

  .portable-text :global(a:hover) {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .portable-text :global(blockquote) {
    border-left: 3px solid var(--primary);
    padding-left: 1.5rem;
    margin: 2.5rem 0;
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--foreground);
    opacity: 0.8;
  }

  .portable-text :global(figure) {
    margin-top: 3rem;
    margin-bottom: 3rem;
  }
  
  .portable-text :global(figure img) {
    width: 100%;
    max-height: 75vh;
    object-fit: contain;
    border-radius: 0.75rem;
  }
  
  .portable-text :global(figcaption) {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--muted-foreground);
    text-align: center;
    font-style: italic;
  }

  .portable-text :global(ul),
  .portable-text :global(ol) {
    margin: 1.75rem 0;
    padding-left: 1.5rem;
  }

  .portable-text :global(ul) {
    list-style-type: disc;
  }

  .portable-text :global(ol) {
    list-style-type: decimal;
  }

  .portable-text :global(li) {
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
  }

  .portable-text :global(li::marker) {
    color: var(--muted-foreground);
  }

  .portable-text :global(hr) {
    border: none;
    text-align: center;
    margin: 3rem 0;
  }
  
  .portable-text :global(hr::before) {
    content: "•••";
    font-size: 1.5rem;
    letter-spacing: 0.5em;
    color: var(--foreground);
    opacity: 0.3;
  }
</style>
