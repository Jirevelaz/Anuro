---
import { Image } from "astro:assets"
import BaseLayout from "../layouts/BaseLayout.astro"
import ProductCard from "../components/ProductCard.astro"
import CollectionNav from "../components/CollectionNav.astro"
import ProductCarousel from "../components/ProductCarousel.astro"
import { sanityClient } from "sanity:client"
import { urlFor } from "../lib/sanity"

const PRODUCT_FIELDS = `_id, title, "slug": slug.current, artist, coverImage, price, badges, collection`

const featured = await sanityClient.fetch(
  `*[_type == "release" && collection == "preventas"] | order(_createdAt desc)[0...8] { ${PRODUCT_FIELDS} }`
)
const recents = await sanityClient.fetch(
  `*[_type == "release" && collection == "disco-del-mes"] | order(_createdAt desc)[0...8] { ${PRODUCT_FIELDS} }`
)
const editions = await sanityClient.fetch(
  `*[_type == "release" && collection == "ediciones-especiales"] | order(_createdAt desc)[0...8] { ${PRODUCT_FIELDS} }`
)
const homeSettings = await sanityClient.fetch(`*[_type == "homeSettings"][0]`)

const heroLabel = homeSettings?.heroLabel || "Disco del Mes · Mayo"
const heroTitle = homeSettings?.heroTitle || "Two Wheels Move The Soul"
const heroArtist = homeSettings?.heroArtist || "Robber Robber"
const heroDescription = homeSettings?.heroDescription || "Indie-rock crudo del Vermont profundo, con ilustración de portada por Chemtots. Vinilo de color humo, gatefold con letras impresas y una postal firmada."
const heroBullets = homeSettings?.heroBullets || [
  "Edición de 500 copias numeradas",
  "Postal firmada por la banda",
  "Envío estimado: 20 de mayo"
]
const heroBadge = homeSettings?.heroBadge || "#84 · 2026"
const heroLink = homeSettings?.heroLink || "/collections/disco-del-mes"
const heroImageUrl = homeSettings?.heroImage ? urlFor(homeSettings.heroImage).width(800).height(600).format("webp").url() : "/images/club-hero.jpg"
---

<BaseLayout>
  {/* COLLECTION NAV */}
  <CollectionNav />

  {/* HERO SECTION */}
  <section class="relative overflow-hidden">
    <div class="paper-grain absolute inset-0 opacity-50 pointer-events-none"></div>

    <div class="relative mx-auto grid max-w-7xl gap-10 px-4 pt-16 pb-12 md:grid-cols-12 md:gap-12 md:px-8 md:pt-20 md:pb-16">
      <div class="md:col-span-6 lg:col-span-5 flex flex-col justify-center">
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground">
          Sello Discográfico Independiente · CDMX
        </p>
        <h1 class="mt-3 font-display text-4xl leading-[1.1] tracking-tight md:text-5xl lg:text-6xl">
          Pon una rana<br />
          en tu tornamesa.
        </h1>
        <p class="mt-6 max-w-md text-base leading-relaxed text-muted-foreground md:text-lg">
          ANURO es un sello discográfico independiente curado a mano desde Ciudad de México.
          Cada mes te enviamos un disco que vale la pena escuchar — y cuidar —
          con ilustración exclusiva, prensaje de color y buena conversación.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/estudio"
            class="inline-flex items-center gap-2 rounded-full bg-foreground px-7 py-3.5 font-display text-sm tracking-wide text-background transition-transform hover:-translate-y-0.5"
          >
            Conoce el Estudio
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
          <a
            href="/collections/disco-del-mes"
            class="inline-flex items-center gap-2 rounded-full border border-foreground/20 px-7 py-3.5 font-display text-sm tracking-wide transition-colors hover:bg-foreground/5"
          >
            Ver tienda
          </a>
        </div>

        <dl class="mt-10 grid max-w-md grid-cols-3 gap-2 border-t border-foreground/10 pt-6">
          {
            [
              { k: "+8", v: "años curando" },
              { k: "+120", v: "discos enviados" },
              { k: "MX → US", v: "envío directo" },
            ].map((s) => (
              <div>
                <dt class="font-display text-2xl">{s.k}</dt>
                <dd class="text-xs text-muted-foreground">{s.v}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      {/* Logo stage */}
      <div class="relative md:col-span-6 lg:col-span-7">
        <div class="relative mx-auto aspect-square w-full max-w-[540px]">
          {/* concentric rings */}
          <svg
            class="absolute inset-0 h-full w-full animate-spin-slow"
            viewBox="0 0 200 200"
            aria-hidden="true"
          >
            <circle cx="100" cy="100" r="98" fill="none" stroke="currentColor" stroke-width="0.4" stroke-dasharray="2 3" class="text-foreground/30" />
            <circle cx="100" cy="100" r="86" fill="none" stroke="currentColor" stroke-width="0.4" stroke-dasharray="1 5" class="text-foreground/20" />
            <circle cx="100" cy="100" r="74" fill="none" stroke="currentColor" stroke-width="0.4" class="text-foreground/15" />
          </svg>

          {/* circular text */}
          <svg
            class="absolute inset-0 h-full w-full animate-spin-slow [animation-direction:reverse]"
            viewBox="0 0 200 200"
            aria-hidden="true"
          >
            <defs>
              <path id="anuroCircle" d="M100,100 m-90,0 a90,90 0 1,1 180,0 a90,90 0 1,1 -180,0" />
            </defs>
            <text class="fill-foreground/50 font-mono" font-size="6" letter-spacing="3">
              <textPath href="#anuroCircle">
                ANURO · SELLLO DISCOGRÁFICO INDEPENDIENTE · CDMX · ANURO · SELLLO DISCOGRÁFICO INDEPENDIENTE · CDMX · ANURO · SELLLO DISCOGRÁFICO INDEPENDIENTE · CDMX ·
              </textPath>
            </text>
          </svg>

          {/* Logo */}
          <Image
            src="/images/muro-logo.png"
            alt="Logo de ANURO"
            width={540}
            height={540}
            class="absolute inset-[10%] h-[80%] w-[80%] object-contain animate-wobble drop-shadow-[0_8px_30px_rgba(20,18,12,0.18)]"
          />

          {/* small ticket labels */}
          <div class="absolute -bottom-2 left-4 rotate-[-6deg] rounded-md bg-foreground px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-background shadow-lg">
            ed. limitada · 500 piezas
          </div>
          <div class="absolute -top-2 right-6 rotate-[5deg] rounded-md bg-accent px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-accent-foreground shadow-lg">
            45 RPM
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* MARQUEE INSPIRACIONAL */}
  <div class="relative overflow-hidden border-y border-foreground/10 bg-foreground py-4 md:py-5">
    <div class="flex w-max animate-marquee-fast will-change-transform">
      {
        [...Array(12)].map(() => (
          <span class="flex shrink-0 items-center gap-6 px-6 font-display text-sm tracking-wide text-background md:text-base">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent" />
            EL ALMA DE LA MÚSICA GIRA EN VINILO
          </span>
        ))
      }
    </div>
  </div>

  {/* PREVENTAS - Carrusel horizontal */}
  <ProductCarousel 
    products={featured} 
    title="Preventas abiertas"
    subtitle="Próximos lanzamientos"
    viewAllHref="/collections/preventas"
  />

  {/* DISCO DEL MES */}
  <section class="relative overflow-hidden border-y border-foreground/10 bg-foreground text-background">
    <div class="paper-grain absolute inset-0 opacity-40 mix-blend-overlay pointer-events-none"></div>
    <div class="relative mx-auto grid max-w-7xl gap-10 px-4 py-16 md:grid-cols-12 md:gap-12 md:px-8 md:py-20">
      <div class="md:col-span-5">
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-background/60">
          {heroLabel}
        </p>
        <h2 class="mt-3 font-display text-4xl leading-[1.1] tracking-tight md:text-5xl lg:text-6xl">
          {heroArtist}
          <br />
          <span class="text-accent">{heroTitle}</span>
        </h2>
        <p class="mt-5 max-w-md text-background/75 leading-relaxed">
          {heroDescription}
        </p>
        <ul class="mt-6 space-y-2 text-sm text-background/80">
          {heroBullets.map((bullet: string) => (
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              {bullet}
            </li>
          ))}
        </ul>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={heroLink}
            class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 font-display text-sm tracking-wide text-accent-foreground transition-transform hover:-translate-y-0.5"
          >
            Comprar ahora
          </a>
          <a
            href="/collections/disco-del-mes"
            class="inline-flex items-center gap-2 rounded-full border border-background/30 px-6 py-3 font-display text-sm tracking-wide text-background transition-colors hover:bg-background/10"
          >
            Discos anteriores
          </a>
        </div>

      </div>
      <div class="md:col-span-7">
        <div class="relative aspect-[4/3] overflow-hidden rounded-3xl border border-background/10">
          <img
            src={heroImageUrl}
            alt={`Ilustración del Disco del Mes — ${heroTitle}`}
            class="h-full w-full object-cover"
            loading="lazy"
            width="800"
            height="600"
          />
          <div class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-accent-foreground">
            {heroBadge}
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* DISCOS ANTERIORES - Carrusel */}
  <ProductCarousel 
    products={recents} 
    title="Lo que ha sonado en ANURO"
    subtitle="Discos del Mes"
    viewAllHref="/collections/disco-del-mes"
  />

  {/* EDICIONES ESPECIALES - Carrusel */}
  <ProductCarousel 
    products={editions} 
    title="Para coleccionistas obsesivos"
    subtitle="Ediciones Especiales"
    viewAllHref="/collections/ediciones-especiales"
  />

  {/* BENEFICIOS */}
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <div class="text-center">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
        Por qué ANURO
      </p>
      <h2 class="mx-auto mt-2 max-w-2xl font-display text-3xl leading-tight tracking-tight md:text-4xl lg:text-5xl">
        Más que vinilos, una <span class="hand-underline">experiencia</span>
      </h2>
    </div>
    
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {[
        {
          icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
          title: "Curado a mano",
          desc: "Cada disco pasa por nuestras manos. Escuchamos, seleccionamos y empacamos con cariño."
        },
        {
          icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
          title: "Ediciones exclusivas",
          desc: "Prensajes de color, ilustraciones originales y materiales que no encontrarás en otro lado."
        },
        {
          icon: "M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z",
          title: "Comunidad",
          desc: "Acceso a preventas, eventos y la conversación con otros coleccionistas."
        }
      ].map((b) => (
        <div class="group rounded-3xl border border-foreground/10 bg-card p-8 transition-colors hover:border-primary/30">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={b.icon} />
            </svg>
          </div>
          <h3 class="font-display text-xl">{b.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* DISTRIBUCIÓN */}
  <section class="mx-auto max-w-7xl px-4 pb-20 md:px-8">
    <a
      href="/distribucion"
      class="group relative grid overflow-hidden rounded-3xl border border-foreground/10 bg-card md:grid-cols-2"
    >
      <div class="relative aspect-[4/3] md:aspect-auto">
        <Image
          src="/images/listening-bar.jpg"
          alt="Listening bar"
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
          loading="lazy"
          width={800}
          height={600}
        />
      </div>
      <div class="flex flex-col justify-center gap-5 p-8 md:p-14">
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground">
          ¿Tienes una tienda, un bar, un proyecto?
        </p>
        <h3 class="font-display text-3xl leading-tight tracking-tight md:text-4xl lg:text-5xl">
          Distribución <span class="hand-underline">mayorista</span>
        </h3>
        <p class="max-w-md text-muted-foreground">
          Trabajamos con listening bars, tiendas independientes, restaurantes y
          coleccionistas. Importación directa, sin intermediarios.
        </p>
        <span class="inline-flex w-fit items-center gap-2 font-display text-sm tracking-wide text-foreground">
          Conocer más
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </span>
      </div>
    </a>
  </section>
</BaseLayout>
</content>
</invoke>
