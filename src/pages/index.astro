---
import BaseLayout from "../layouts/BaseLayout.astro"
import ProductCard from "../components/ProductCard.astro"
import CollectionNav from "../components/CollectionNav.astro"
import { discoDelMes, edicionesEspeciales, preventas } from "../data/products"

const featured = preventas.slice(0, 4)
const recents = discoDelMes.slice(0, 4)
const editions = edicionesEspeciales.slice(0, 4)
---

<BaseLayout>
  {/* HERO — MURO logo as the centerpiece */}
  <section class="relative overflow-hidden">
    <div class="paper-grain absolute inset-0 opacity-50 pointer-events-none"></div>

    <div class="relative mx-auto grid max-w-7xl gap-10 px-4 pt-10 pb-16 md:grid-cols-12 md:gap-12 md:px-8 md:pt-16 md:pb-24">
      <div class="md:col-span-6 lg:col-span-5 flex flex-col justify-center">
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground">
          Edición · Mayo · 2026
        </p>
        <h1 class="mt-3 font-display text-5xl leading-[0.95] tracking-tight md:text-6xl lg:text-7xl">
          Pon una rana<br />
          en tu tornamesa.
        </h1>
        <p class="mt-6 max-w-md text-base leading-relaxed text-muted-foreground md:text-lg">
          ANURO es un club de vinilos curado a mano desde Ciudad de México.
          Cada mes te enviamos un disco que vale la pena escuchar — y cuidar —
          con ilustración exclusiva, prensaje de color y buena conversación.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/pages/planes"
            class="inline-flex items-center gap-2 rounded-full bg-foreground px-7 py-3.5 font-display text-sm uppercase tracking-wide text-background transition-transform hover:-translate-y-0.5"
          >
            Únete al Club
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
          <a
            href="/collections/disco-del-mes"
            class="inline-flex items-center gap-2 rounded-full border border-foreground/20 px-7 py-3.5 font-display text-sm uppercase tracking-wide transition-colors hover:bg-foreground/5"
          >
            Ver tienda
          </a>
        </div>

        <dl class="mt-10 grid max-w-md grid-cols-3 gap-2 border-t border-foreground/10 pt-6">
          {
            [
              { k: "+8", v: "años curando" },
              { k: "+120", v: "discos enviados" },
              { k: "MX → US", v: "envío directo" },
            ].map((s) => (
              <div>
                <dt class="font-display text-2xl">{s.k}</dt>
                <dd class="text-xs text-muted-foreground">{s.v}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      {/* Logo stage */}
      <div class="relative md:col-span-6 lg:col-span-7">
        <div class="relative mx-auto aspect-square w-full max-w-[640px]">
          {/* concentric hand-drawn rings */}
          <svg
            class="absolute inset-0 h-full w-full animate-spin-slow"
            viewBox="0 0 200 200"
            aria-hidden="true"
          >
            <circle cx="100" cy="100" r="98" fill="none" stroke="currentColor" stroke-width="0.4" stroke-dasharray="2 3" />
            <circle cx="100" cy="100" r="86" fill="none" stroke="currentColor" stroke-width="0.4" stroke-dasharray="1 5" />
            <circle cx="100" cy="100" r="74" fill="none" stroke="currentColor" stroke-width="0.4" />
          </svg>

          {/* circular text */}
          <svg
            class="absolute inset-0 h-full w-full animate-spin-slow [animation-direction:reverse]"
            viewBox="0 0 200 200"
            aria-hidden="true"
          >
            <defs>
              <path id="muroCircle" d="M100,100 m-90,0 a90,90 0 1,1 180,0 a90,90 0 1,1 -180,0" />
            </defs>
            <text class="fill-foreground/70 font-mono" font-size="6" letter-spacing="3">
              <textPath href="#muroCircle">
                MURO · CLUB DE VINILOS · CDMX · MURO · CLUB DE VINILOS · CDMX · MURO · CLUB DE VINILOS · CDMX ·
              </textPath>
            </text>
          </svg>

          {/* Logo */}
          <img
            src="/images/muro-logo.png"
            alt="Logo de MURO"
            width="640"
            height="640"
            class="absolute inset-[8%] h-[84%] w-[84%] object-contain animate-wobble drop-shadow-[0_8px_30px_rgba(20,18,12,0.18)]"
          />

          {/* small ticket label */}
          <div class="absolute -bottom-4 left-2 rotate-[-6deg] rounded-md bg-foreground px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-background shadow-lg">
            ed. limitada · 500 piezas
          </div>
          <div class="absolute -top-2 right-4 rotate-[5deg] rounded-md bg-accent px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-accent-foreground shadow-lg">
            45 RPM
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* COLLECTION NAV STRIP */}
  <CollectionNav />

  {/* PRÓXIMOS LANZAMIENTOS */}
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
          Próximos lanzamientos
        </p>
        <h2 class="mt-2 font-display text-4xl leading-tight tracking-tight md:text-5xl">
          <span class="hand-underline">Preventas</span> abiertas
        </h2>
      </div>
      <a
        href="/collections/preventas"
        class="font-mono text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground"
      >
        Ver todas →
      </a>
    </div>
    <div class="grid grid-cols-2 gap-x-5 gap-y-12 md:grid-cols-4">
      {featured.map((p) => <ProductCard product={p} />)}
    </div>
  </section>

  {/* DISCO DEL MES feature strip */}
  <section class="relative overflow-hidden border-y border-foreground/10 bg-foreground text-background">
    <div class="paper-grain absolute inset-0 opacity-40 mix-blend-overlay pointer-events-none"></div>
    <div class="relative mx-auto grid max-w-7xl gap-10 px-4 py-16 md:grid-cols-12 md:gap-12 md:px-8 md:py-20">
      <div class="md:col-span-5">
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-background/60">
          Disco del Mes · Mayo
        </p>
        <h2 class="mt-3 font-display text-5xl leading-[0.95] tracking-tight md:text-6xl">
          Robber Robber
          <br />
          <span class="text-accent">Two Wheels Move The Soul</span>
        </h2>
        <p class="mt-5 max-w-md text-background/75 leading-relaxed">
          Indie-rock crudo del Vermont profundo, con ilustración de portada por
          <span class="text-background">Chemtots</span>. Vinilo de color humo,
          gatefold con letras impresas y una postal firmada.
        </p>
        <ul class="mt-6 space-y-2 text-sm text-background/80">
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            Edición de 500 copias numeradas
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            Postal firmada por la banda
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            Envío estimado: 20 de abril
          </li>
        </ul>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/pages/planes"
            class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 font-display text-sm uppercase tracking-wide text-accent-foreground transition-transform hover:-translate-y-0.5"
          >
            Suscríbete y recíbelo
          </a>
          <a
            href="/collections/disco-del-mes"
            class="inline-flex items-center gap-2 rounded-full border border-background/30 px-6 py-3 font-display text-sm uppercase tracking-wide text-background transition-colors hover:bg-background/10"
          >
            Discos anteriores
          </a>
        </div>
      </div>
      <div class="md:col-span-7">
        <div class="relative aspect-[4/3] overflow-hidden rounded-3xl border border-background/10">
          <img
            src="/images/club-hero.jpg"
            alt="Ilustración del Disco del Mes — Two Wheels Move The Soul"
            class="h-full w-full object-cover"
            loading="lazy"
          />
          <div class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-accent-foreground">
            #84 · 2026
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* DISCOS ANTERIORES */}
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
          Discos del Mes
        </p>
        <h2 class="mt-2 font-display text-4xl leading-tight tracking-tight md:text-5xl">
          Lo que ha sonado en MURO
        </h2>
      </div>
      <a
        href="/collections/disco-del-mes"
        class="font-mono text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground"
      >
        Ver todos →
      </a>
    </div>
    <div class="grid grid-cols-2 gap-x-5 gap-y-12 md:grid-cols-4">
      {recents.map((p) => <ProductCard product={p} />)}
    </div>
  </section>

  {/* EDICIONES ESPECIALES */}
  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-8 md:pb-20">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
          Ediciones Especiales
        </p>
        <h2 class="mt-2 font-display text-4xl leading-tight tracking-tight md:text-5xl">
          Para coleccionistas <em class="not-italic text-accent">obsesivos</em>.
        </h2>
      </div>
      <a
        href="/collections/ediciones-especiales"
        class="font-mono text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground"
      >
        Ver todas →
      </a>
    </div>
    <div class="grid grid-cols-2 gap-x-5 gap-y-12 md:grid-cols-4">
      {editions.map((p) => <ProductCard product={p} />)}
    </div>
  </section>

  {/* DISTRIBUCIÓN teaser */}
  <section class="mx-auto max-w-7xl px-4 pb-20 md:px-8">
    <a
      href="/pages/distribucion-y-mayoreo"
      class="group relative grid overflow-hidden rounded-3xl border border-foreground/10 bg-card md:grid-cols-2"
    >
      <div class="relative aspect-[4/3] md:aspect-auto">
        <img
          src="/images/listening-bar.jpg"
          alt="Listening bar"
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col justify-center gap-5 p-8 md:p-14">
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground">
          ¿Tienes una tienda, un bar, un proyecto?
        </p>
        <h3 class="font-display text-4xl leading-tight tracking-tight md:text-5xl">
          Distribución <span class="hand-underline">mayorista</span>
        </h3>
        <p class="max-w-md text-muted-foreground">
          Trabajamos con listening bars, tiendas independientes, restaurantes y
          coleccionistas. Importación directa, sin intermediarios.
        </p>
        <span class="inline-flex w-fit items-center gap-2 font-display text-sm uppercase tracking-wide text-foreground">
          Conocer más
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </span>
      </div>
    </a>
  </section>
</BaseLayout>
