---
import BaseLayout from "../../layouts/BaseLayout.astro"

const posts = [
  {
    title: "GYRO x MARVILLA",
    excerpt:
      "Una colaboración entre dos amantes del 45 RPM. Pucks de aluminio anodizado para que tus singles giren con estilo.",
    date: "24 jun 2025",
    image: "/images/vinyl-knobs.jpg",
    category: "Colaboración",
    featured: true,
  },
  {
    title: "Cómo limpiamos los discos en ANURO",
    excerpt:
      "Una guía paso a paso sobre nuestro proceso de limpieza ultrasónica y por qué importa más de lo que crees.",
    date: "12 may 2025",
    image: "/images/listening-bar.jpg",
    category: "Cuidado",
  },
  {
    title: "El renacer del cassette",
    excerpt:
      "Cómo el formato más caprichoso de los 80 volvió, otra vez, y por qué nos parece una excelente noticia.",
    date: "03 may 2025",
    image: "/images/accessory-cassettes.jpg",
    category: "Formato",
  },
  {
    title: "5 listening bars para visitar en CDMX",
    excerpt:
      "Mapa actualizado de los espacios donde la curaduría musical es tan importante como los tragos.",
    date: "21 abr 2025",
    image: "/images/showroom.jpg",
    category: "Guía",
  },
  {
    title: "Notas sobre Robber Robber",
    excerpt:
      "Por qué elegimos a esta banda de Vermont como Disco del Mes y qué esperar del prensaje exclusivo.",
    date: "10 abr 2025",
    image: "/images/club-hero.jpg",
    category: "Disco del Mes",
  },
] as const

const [featured, ...rest] = posts
---

<BaseLayout title="Bitácora · ANURO" description="Notas, ensayos y curaduría desde el club de vinilos ANURO.">
  {/* HERO */}
  <section class="relative overflow-hidden border-b border-foreground/10">
    <div class="paper-grain absolute inset-0 opacity-50 pointer-events-none"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-12 md:px-8 md:py-16">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground">
        Bitácora
      </p>
      <h1 class="mt-3 font-display text-5xl leading-[0.95] tracking-tight md:text-7xl">
        Notas desde <span class="hand-underline">el club</span>.
      </h1>
      <p class="mt-5 max-w-2xl text-muted-foreground md:text-lg">
        Curaduría, ensayos, entrevistas, y todo lo que pasa entre bambalinas
        cuando armamos un Disco del Mes.
      </p>
    </div>
  </section>

  {/* FEATURED POST */}
  <section class="mx-auto max-w-7xl px-4 pt-12 md:px-8 md:pt-16">
    <a
      href="#"
      class="group relative grid gap-8 overflow-hidden rounded-3xl border border-foreground/10 bg-card md:grid-cols-2 md:gap-0"
    >
      <div class="relative aspect-[4/3] md:aspect-auto">
        <img
          src={featured.image}
          alt={featured.title}
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
          loading="lazy"
        />
        <span class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-accent-foreground">
          Destacado
        </span>
      </div>
      <div class="flex flex-col justify-center gap-4 p-8 md:p-14">
        <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
          <span>{featured.category}</span>
          <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
          <time>{featured.date}</time>
        </div>
        <h2 class="font-display text-4xl leading-tight tracking-tight md:text-5xl">
          {featured.title}
        </h2>
        <p class="text-muted-foreground leading-relaxed md:text-lg">
          {featured.excerpt}
        </p>
        <span class="inline-flex w-fit items-center gap-2 font-display text-sm uppercase tracking-wide">
          Leer más
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </span>
      </div>
    </a>
  </section>

  {/* POST GRID */}
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-2">
      {
        rest.map((p) => (
          <a href="#" class="group flex flex-col gap-5 md:flex-row">
            <div class="relative aspect-[4/3] w-full shrink-0 overflow-hidden rounded-2xl bg-card md:w-1/2">
              <img
                src={p.image}
                alt={p.title}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                loading="lazy"
              />
            </div>
            <div class="flex flex-1 flex-col justify-center gap-3">
              <div class="flex items-center gap-3 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                <span>{p.category}</span>
                <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
                <time>{p.date}</time>
              </div>
              <h3 class="font-display text-2xl leading-tight transition-colors group-hover:text-accent md:text-3xl">
                {p.title}
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                {p.excerpt}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
