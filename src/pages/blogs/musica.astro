---
import BaseLayout from "../../layouts/BaseLayout.astro"

// Categorías de música
const categories = [
  { name: "Todo", slug: "todo", active: true },
  { name: "Reseñas", slug: "resenas" },
  { name: "Entrevistas", slug: "entrevistas" },
  { name: "Curaduría", slug: "curaduria" },
  { name: "Guías", slug: "guias" },
  { name: "Detrás del Disco", slug: "detras-del-disco" },
]

// Posts de música
const posts = [
  {
    title: "GYRO x MARVILLA: El arte de girar a 45 RPM",
    excerpt:
      "Una colaboración entre dos amantes del single. Pucks de aluminio anodizado que hacen girar tus 7 pulgadas con estilo y precisión.",
    date: "24 jun 2025",
    image: "/images/vinyl-knobs.jpg",
    category: "Colaboración",
    author: "Equipo ANURO",
    readTime: "5 min",
    featured: true,
  },
  {
    title: "Robber Robber: El sonido de Vermont llega a tu tornamesa",
    excerpt:
      "Por qué elegimos a esta banda de Vermont como Disco del Mes y qué esperar del prensaje exclusivo en vinilo verde bosque.",
    date: "10 abr 2025",
    image: "/images/club-hero.jpg",
    category: "Disco del Mes",
    author: "Fernanda Solís",
    readTime: "8 min",
  },
  {
    title: "5 listening bars para visitar en CDMX",
    excerpt:
      "Mapa actualizado de los espacios donde la curaduría musical es tan importante como los tragos. Desde Condesa hasta Coyoacán.",
    date: "21 abr 2025",
    image: "/images/showroom.jpg",
    category: "Guía",
    author: "Marco Ríos",
    readTime: "6 min",
  },
  {
    title: "Cómo limpiamos los discos en ANURO",
    excerpt:
      "Una guía paso a paso sobre nuestro proceso de limpieza ultrasónica y por qué importa más de lo que crees para preservar tu colección.",
    date: "12 may 2025",
    image: "/images/listening-bar.jpg",
    category: "Cuidado",
    author: "Equipo ANURO",
    readTime: "4 min",
  },
  {
    title: "El renacer del cassette en 2025",
    excerpt:
      "Cómo el formato más caprichoso de los 80 volvió, otra vez, y por qué nos parece una excelente noticia para los coleccionistas.",
    date: "03 may 2025",
    image: "/images/accessory-cassettes.jpg",
    category: "Formato",
    author: "Diana Mora",
    readTime: "7 min",
  },
  {
    title: "Entrevista: Los Blenders y el vinilo como ritual",
    excerpt:
      "Hablamos con la banda tapatía sobre su relación con el formato físico y por qué decidieron prensar su último álbum en doble LP.",
    date: "28 mar 2025",
    image: "/images/promo-plans.jpg",
    category: "Entrevista",
    author: "Fernanda Solís",
    readTime: "12 min",
  },
] as const

const [featured, ...rest] = posts
---

<BaseLayout title="Música · ANURO" description="Reseñas, entrevistas y curaduría musical desde el club de vinilos ANURO.">
  
  <!-- HERO EDITORIAL -->
  <section class="relative border-b border-foreground/10">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-primary">
            Blog de Música
          </p>
          <h1 class="mt-4 font-display text-5xl leading-[0.95] tracking-tight md:text-7xl lg:text-8xl">
            Notas desde<br />
            <span class="text-primary">el tocadiscos</span>
          </h1>
        </div>
        <p class="max-w-sm text-muted-foreground md:text-right md:text-lg">
          Curaduría, reseñas, entrevistas y todo lo que pasa entre bambalinas del club.
        </p>
      </div>
    </div>
  </section>

  <!-- CATEGORY FILTER BAR -->
  <section class="sticky top-0 z-40 border-b border-foreground/10 bg-background/95 backdrop-blur-sm">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <nav class="flex items-center gap-1 overflow-x-auto py-4 scrollbar-hide">
        {
          categories.map((cat) => (
            <a
              href={cat.slug === "todo" ? "/blogs/musica" : `/blogs/musica?categoria=${cat.slug}`}
              class:list={[
                "shrink-0 rounded-full px-4 py-2 font-mono text-xs uppercase tracking-wider transition-colors",
                cat.active
                  ? "bg-foreground text-background"
                  : "text-muted-foreground hover:bg-foreground/5 hover:text-foreground",
              ]}
            >
              {cat.name}
            </a>
          ))
        }
      </nav>
    </div>
  </section>

  <!-- FEATURED ARTICLE -->
  <section class="mx-auto max-w-7xl px-4 py-12 md:px-8 md:py-16">
    <a
      href="#"
      class="group relative grid gap-0 overflow-hidden rounded-2xl border border-foreground/10 bg-card md:grid-cols-2"
    >
      <!-- Image -->
      <div class="relative aspect-[4/3] overflow-hidden md:aspect-auto md:min-h-[480px]">
        <img
          src={featured.image}
          alt={featured.title}
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-foreground/20 to-transparent md:bg-gradient-to-r md:from-transparent md:to-foreground/10"></div>
        
        <!-- Category Badge -->
        <span class="absolute left-4 top-4 rounded-full bg-primary px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-primary-foreground">
          {featured.category}
        </span>
      </div>
      
      <!-- Content -->
      <div class="flex flex-col justify-center gap-6 p-8 md:p-12 lg:p-16">
        <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
          <span>{featured.author}</span>
          <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
          <time>{featured.date}</time>
          <span class="h-1 w-1 rounded-full bg-foreground/30"></span>
          <span>{featured.readTime}</span>
        </div>
        
        <h2 class="font-display text-3xl leading-tight tracking-tight md:text-4xl lg:text-5xl">
          {featured.title}
        </h2>
        
        <p class="text-muted-foreground leading-relaxed md:text-lg">
          {featured.excerpt}
        </p>
        
        <span class="inline-flex w-fit items-center gap-3 rounded-full border border-foreground/20 px-5 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors group-hover:border-primary group-hover:bg-primary group-hover:text-primary-foreground">
          Leer artículo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </div>
    </a>
  </section>

  <!-- ARTICLES GRID -->
  <section class="mx-auto max-w-7xl px-4 pb-20 md:px-8">
    <div class="mb-8 flex items-center justify-between border-b border-foreground/10 pb-4">
      <h3 class="font-display text-2xl">Últimos artículos</h3>
      <span class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
        {rest.length} artículos
      </span>
    </div>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        rest.map((post, i) => (
          <a href="#" class="group flex flex-col">
            <!-- Image Container -->
            <div class="relative aspect-[4/3] overflow-hidden rounded-xl bg-muted">
              <img
                src={post.image}
                alt={post.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <!-- Category Pill -->
              <span class="absolute left-3 top-3 rounded-full bg-background/90 px-2.5 py-1 font-mono text-[9px] uppercase tracking-widest backdrop-blur-sm">
                {post.category}
              </span>
            </div>
            
            <!-- Content -->
            <div class="flex flex-1 flex-col gap-3 pt-5">
              <!-- Meta -->
              <div class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                <time>{post.date}</time>
                <span class="h-0.5 w-0.5 rounded-full bg-foreground/30"></span>
                <span>{post.readTime}</span>
              </div>
              
              <!-- Title -->
              <h4 class="font-display text-xl leading-tight transition-colors group-hover:text-primary md:text-2xl">
                {post.title}
              </h4>
              
              <!-- Excerpt -->
              <p class="line-clamp-2 text-sm leading-relaxed text-muted-foreground">
                {post.excerpt}
              </p>
              
              <!-- Author -->
              <div class="mt-auto flex items-center gap-2 pt-3">
                <div class="h-6 w-6 rounded-full bg-primary/10"></div>
                <span class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground">
                  {post.author}
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- NEWSLETTER SECTION -->
  <section class="border-t border-foreground/10 bg-foreground text-background">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-background/60">
          Newsletter
        </p>
        <h2 class="mt-4 font-display text-4xl leading-tight md:text-5xl">
          No te pierdas nada
        </h2>
        <p class="mt-4 text-background/70 md:text-lg">
          Recibe las últimas notas, discos del mes y ofertas exclusivas directo a tu correo.
        </p>
        
        <form class="mt-8 flex flex-col gap-3 sm:flex-row sm:gap-0">
          <input
            type="email"
            placeholder="tu@correo.com"
            class="flex-1 rounded-full border border-background/20 bg-transparent px-6 py-3.5 text-background placeholder:text-background/40 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 sm:rounded-r-none"
          />
          <button
            type="submit"
            class="rounded-full bg-primary px-8 py-3.5 font-mono text-xs uppercase tracking-wider text-primary-foreground transition-colors hover:bg-primary/90 sm:rounded-l-none"
          >
            Suscribirse
          </button>
        </form>
        
        <p class="mt-4 font-mono text-[10px] uppercase tracking-wider text-background/40">
          Sin spam. Solo música y buena vibra.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
