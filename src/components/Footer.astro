---
import { Image } from "astro:assets"
import { sanityClient } from "sanity:client"

const year = new Date().getFullYear()

const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`)
const social = siteSettings?.socialLinks || {}
const contact = siteSettings?.contactInfo || {}
---

<footer class="relative mt-24 border-t border-foreground/15 bg-foreground text-background">
  <div class="paper-grain absolute inset-0 opacity-40 mix-blend-overlay pointer-events-none"></div>

  <div class="relative mx-auto grid max-w-7xl gap-12 px-4 py-16 md:grid-cols-3 md:px-8">
    <div class="space-y-5">
      <div class="flex items-center gap-3">
        <Image
          src="/images/muro-logo.png"
          alt=""
          width={56}
          height={56}
          class="h-14 w-14 object-contain invert-0"
        />
        <div class="flex flex-col leading-none">
          <span class="font-display text-3xl tracking-tight">ANURO</span>
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-background/60">
            Sello discográfico
          </span>
        </div>
      </div>
      <p class="max-w-xs text-sm leading-relaxed text-background/70">
        Cuidamos los discos como cuida una rana las hojas: con paciencia, con paciencia y mucha música.
      </p>
      <div class="flex gap-2">
        {social.instagram && (
          <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="grid h-10 w-10 place-items-center rounded-full border border-background/20 text-background/80 transition-colors hover:border-primary hover:text-primary">
            <span class="font-mono text-[10px] uppercase">I</span>
          </a>
        )}
        {social.facebook && (
          <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="grid h-10 w-10 place-items-center rounded-full border border-background/20 text-background/80 transition-colors hover:border-primary hover:text-primary">
            <span class="font-mono text-[10px] uppercase">F</span>
          </a>
        )}
        {social.youtube && (
          <a href={social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="grid h-10 w-10 place-items-center rounded-full border border-background/20 text-background/80 transition-colors hover:border-primary hover:text-primary">
            <span class="font-mono text-[10px] uppercase">Y</span>
          </a>
        )}
      </div>
    </div>

    <div id="newsletter-container">
      <h3 class="font-display text-lg uppercase tracking-tight">Boletín</h3>
      <p id="newsletter-text" class="mt-2 text-sm text-background/70">
        Suscríbete y recibe primero las nuevas ediciones y preventas.
      </p>
      <form 
        id="newsletter-form"
        name="newsletter"
        method="POST"
        data-netlify="true"
        class="mt-5 flex w-full max-w-sm overflow-hidden rounded-full border border-background/20 bg-background/5"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <input
          type="email"
          name="email"
          required
          placeholder="tu@correo.com"
          class="flex-1 bg-transparent px-5 py-3 text-sm text-background outline-none placeholder:text-background/50"
        />
        <button
          type="submit"
          class="bg-accent px-5 text-sm font-semibold uppercase tracking-wide text-accent-foreground transition-colors hover:bg-accent/90"
        >
          Enviar
        </button>
      </form>
      <p id="newsletter-success" class="hidden mt-4 text-sm font-semibold text-accent">
        ¡Gracias! Te has suscrito correctamente.
      </p>
    </div>

    <script is:inline>
      const newsForm = document.getElementById('newsletter-form');
      const newsSuccess = document.getElementById('newsletter-success');
      const newsText = document.getElementById('newsletter-text');

      if (newsForm) {
        newsForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const formData = new FormData(newsForm);
          
          fetch('/', {
            method: 'POST',
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams(formData).toString()
          })
          .then(() => {
            newsForm.classList.add('hidden');
            newsText.classList.add('hidden');
            newsSuccess.classList.remove('hidden');
          })
          .catch((error) => console.error('Error:', error));
        });
      }
    </script>

    <div class="grid grid-cols-2 gap-8 text-sm">
      <div>
        <h3 class="mb-4 font-display text-lg uppercase tracking-tight">Información</h3>
        <ul class="space-y-2.5 text-background/70">
          <li><a href="/" class="transition-colors hover:text-background">Políticas de Venta</a></li>
          <li><a href="/" class="transition-colors hover:text-background">Preguntas Frecuentes</a></li>
          <li><a href="/" class="transition-colors hover:text-background">Aviso de Privacidad</a></li>
          <li><a href="/" class="transition-colors hover:text-background">Términos y Condiciones</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-4 font-display text-lg uppercase tracking-tight">Contacto</h3>
        <ul class="space-y-2.5 text-background/70">
          {contact.whatsapp && <li>WhatsApp · {contact.whatsapp}</li>}
          {contact.email && <li>{contact.email}</li>}
          <li>Ciudad de México</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="relative border-t border-background/15">
    <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-5 text-xs text-background/60 md:flex-row md:items-center md:justify-between md:px-8">
      <p>
        <span class="text-accent">ANURO</span>, {year}. Todos los derechos
        reservados.
      </p>
      <p>Hecho a mano en CDMX · Diseño con cariño</p>
    </div>
  </div>
</footer>
