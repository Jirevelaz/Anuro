---
import type { Product } from "../data/products"
import ProductCard from "./ProductCard.astro"

interface Props {
  products: Product[]
  title: string
  subtitle?: string
  viewAllHref?: string
  viewAllLabel?: string
}

const { 
  products, 
  title, 
  subtitle, 
  viewAllHref,
  viewAllLabel = "Ver todos →"
} = Astro.props
---

<section class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
  <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
      {subtitle && (
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
          {subtitle}
        </p>
      )}
      <h2 class="mt-2 font-display text-3xl leading-tight tracking-tight md:text-4xl lg:text-5xl">
        {title}
      </h2>
    </div>
    <div class="flex items-center gap-3">
      {viewAllHref && (
        <a
          href={viewAllHref}
          class="font-mono text-xs uppercase tracking-wider text-muted-foreground transition-colors hover:text-foreground"
        >
          {viewAllLabel}
        </a>
      )}
      <div class="hidden gap-1 sm:flex">
        <button
          type="button"
          data-carousel-prev
          class="grid h-9 w-9 place-items-center rounded-full border border-foreground/20 text-foreground transition-colors hover:bg-foreground hover:text-background disabled:opacity-40"
          aria-label="Anterior"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button
          type="button"
          data-carousel-next
          class="grid h-9 w-9 place-items-center rounded-full border border-foreground/20 text-foreground transition-colors hover:bg-foreground hover:text-background disabled:opacity-40"
          aria-label="Siguiente"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>
  
  <div class="product-carousel relative -mx-4 md:-mx-8" data-product-carousel>
    <div 
      class="carousel-track flex gap-5 overflow-x-auto scroll-smooth px-4 pb-4 scrollbar-hide md:px-8" 
      data-track
      style="scroll-snap-type: x mandatory;"
    >
      {products.map((product) => (
        <div class="w-[70vw] shrink-0 sm:w-[45vw] md:w-[calc(25%-15px)]" style="scroll-snap-align: start;">
          <ProductCard product={product} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  document.querySelectorAll('[data-product-carousel]').forEach((carousel) => {
    const track = carousel.querySelector('[data-track]') as HTMLElement
    const prevBtn = carousel.parentElement?.querySelector('[data-carousel-prev]')
    const nextBtn = carousel.parentElement?.querySelector('[data-carousel-next]')
    
    const scrollAmount = 320
    
    prevBtn?.addEventListener('click', () => {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' })
    })
    
    nextBtn?.addEventListener('click', () => {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' })
    })
  })
</script>
