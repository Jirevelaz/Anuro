---
interface Props {
  count: number
}
const { count } = Astro.props
---

<div class="flex flex-wrap items-center justify-between gap-4 py-6">
  <div class="flex items-center gap-3">
    <button
      type="button"
      class="inline-flex items-center gap-2 rounded-full border border-foreground/20 px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-foreground hover:text-background"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
      Filtrar
    </button>
    <span class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
      {count} {count === 1 ? "disco" : "discos"}
    </span>
  </div>

  <label class="inline-flex items-center gap-2 rounded-full border border-foreground/20 bg-card px-4 py-1.5 text-sm">
    <span class="text-muted-foreground">Ordenar:</span>
    <select class="cursor-pointer bg-transparent py-1 pr-2 font-medium outline-none">
      <option>Más vendidos</option>
      <option>Más recientes</option>
      <option>Precio: menor a mayor</option>
      <option>Precio: mayor a menor</option>
      <option>Alfabético</option>
    </select>
  </label>
</div>
