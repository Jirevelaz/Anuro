---
interface Props {
  text?: string
  variant?: "light" | "dark"
}

const {
  text = "EL ALMA DE LA MÚSICA GIRA EN VINILO — CLÁSICOS, RAREZAS Y JOYAS QUE MERECEN SER ESCUCHADAS",
  variant = "light",
} = Astro.props

const items = Array.from({ length: 6 })

const styles = {
  light: "bg-card border-y border-foreground/10 text-foreground",
  dark: "bg-foreground text-background"
}
---

<div class={`relative overflow-hidden py-4 md:py-5 ${styles[variant]}`}>
  <div class="flex w-max animate-marquee-fast will-change-transform">
    {
      [...items, ...items].map(() => (
        <span class="flex shrink-0 items-center gap-8 px-8 font-display text-sm uppercase tracking-wide md:text-lg">
          <span class="flex items-center gap-3">
            <span class="inline-block h-2 w-2 rounded-full bg-accent" />
            {text}
          </span>
        </span>
      ))
    }
  </div>
</div>
