---
import { urlFor } from "../../lib/sanity"

export interface Props {
  node: {
    images?: Array<{
      _key: string
      asset: any
      alt?: string
    }>
  }
}

const { node } = Astro.props
const images = node.images || []
---

{images.length > 0 && (
  <figure class="full-bleed-figure my-14">
    <div class:list={[
      "grid gap-2 px-4 md:px-8",
      images.length === 1 && "grid-cols-1 max-w-4xl mx-auto",
      images.length === 2 && "grid-cols-2",
      images.length >= 3 && "grid-cols-2 md:grid-cols-3",
    ]}>
      {images.map((img) => (
        <div class="overflow-hidden rounded-xl bg-muted aspect-[4/3]">
          <img
            src={urlFor(img).width(900).height(675).format("webp").url()}
            alt={img.alt || ""}
            class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </figure>
)}

<style>
  .full-bleed-figure {
    width: 100vw;
    max-width: 900px;
    margin-left: calc(50% - min(50vw, 450px));
    margin-right: calc(50% - min(50vw, 450px));
    position: relative;
  }
</style>
