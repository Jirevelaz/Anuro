---
import { urlFor } from "../../lib/sanity"

export interface Props {
  node: {
    images?: Array<{
      _key: string
      asset: any
      alt?: string
    }>
  }
}

const { node } = Astro.props
const images = node.images || []
---

{images.length > 0 && (
  <figure class="my-14 relative w-[calc(100%+2rem)] -ml-4 md:w-[120%] md:-ml-[10%] lg:w-[130%] lg:-ml-[15%] max-w-[100vw]">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 px-4 md:px-0">
      {images.map((img) => (
        <div class="overflow-hidden rounded-xl bg-muted aspect-[4/3]">
          <img
            src={urlFor(img).width(800).height(600).format("webp").url()}
            alt={img.alt || "Imagen de galería"}
            class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </figure>
)}
