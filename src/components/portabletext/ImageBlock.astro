---
import { urlFor } from "../../lib/sanity"

export interface Props {
  node: {
    asset: any
    alt?: string
    caption?: string
  }
}

const { node } = Astro.props
---

{node.asset && (
  <figure class="full-bleed-figure my-14">
    <div class="overflow-hidden md:rounded-2xl bg-muted">
      <img
        src={urlFor(node).width(1400).format("webp").url()}
        alt={node.alt || node.caption || "Imagen del artículo"}
        class="w-full h-auto object-cover"
        loading="lazy"
      />
    </div>
    {node.caption && (
      <figcaption class="mt-3 text-center text-sm italic text-muted-foreground px-4">
        {node.caption}
      </figcaption>
    )}
  </figure>
)}

<style>
  .full-bleed-figure {
    /*
     * El truco: salirse del contenedor usando 100vw.
     * Limitamos el ancho máximo a 1200px para que no sea gigante en PC.
     * margin-left: calc(50% - min(50vw, 600px)) lo centra correctamente.
     */
    width: 100vw;
    max-width: 1200px;
    margin-left: calc(50% - min(50vw, 600px));
    margin-right: calc(50% - min(50vw, 600px));
    position: relative;
  }
</style>
