---
import { urlFor } from "../../lib/sanity"

export interface Props {
  node: {
    asset: any
    alt?: string
    caption?: string
  }
}

const { node } = Astro.props
---

{node.asset && (
  <figure class="my-14 relative w-[calc(100%+2rem)] -ml-4 md:w-[120%] md:-ml-[10%] lg:w-[130%] lg:-ml-[15%] max-w-[100vw]">
    <div class="overflow-hidden md:rounded-2xl bg-muted">
      <img
        src={urlFor(node).width(1200).format("webp").url()}
        alt={node.alt || node.caption || "Imagen del artículo"}
        class="w-full h-auto object-cover"
        loading="lazy"
      />
    </div>
    {node.caption && (
      <figcaption class="mt-3 text-center text-sm italic text-muted-foreground">
        {node.caption}
      </figcaption>
    )}
  </figure>
)}
