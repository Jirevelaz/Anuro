---
import { urlFor } from "../../lib/sanity"

export interface Props {
  node: {
    asset: any
    alt?: string
    caption?: string
  }
}

const { node } = Astro.props
---

{node.asset && (
  <figure class="full-bleed-figure my-14">
    <div class="overflow-hidden md:rounded-2xl bg-muted flex justify-center">
      <img
        src={urlFor(node).width(1200).format("webp").url()}
        alt={node.alt || node.caption || "Imagen del artículo"}
        class="w-full h-auto max-h-[75vh] object-contain"
        loading="lazy"
      />
    </div>
    {node.caption && (
      <figcaption class="mt-3 text-center text-sm italic text-muted-foreground px-4">
        {node.caption}
      </figcaption>
    )}
  </figure>
)}

<style>
  .full-bleed-figure {
    /*
     * Breakout style: wider than text but capped for readability.
     * matching hero width (approx 900px)
     */
    width: 100vw;
    max-width: 900px;
    margin-left: calc(50% - min(50vw, 450px));
    margin-right: calc(50% - min(50vw, 450px));
    position: relative;
  }
</style>
